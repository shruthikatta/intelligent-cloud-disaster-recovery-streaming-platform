# Copy to .env for local mock mode
APP_MODE=mock
USE_REAL_AWS=false
PRIMARY_REGION=us-west-2
DR_REGION=us-east-1
ENABLE_SNS=false
ENABLE_SQS=false

DATABASE_URL=sqlite+aiosqlite:///./data/streamvault.db
JWT_SECRET=change-me-for-demo

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# After training (see docs/RUN_INSTRUCTIONS.md)
ML_MODEL_PATH=services/ml_predictor/models/ed_lstm_demo.keras

# Optional standalone ML service
ML_USE_STANDALONE_SERVICE=false
ML_SERVICE_URL=http://127.0.0.1:8001
