# AWS-capable mode — copy to .env.aws and merge into .env for presentations.
# Never commit real secrets. Prefer IAM roles on EC2/Lambda in production.

APP_MODE=aws
USE_REAL_AWS=true
PRIMARY_REGION=us-west-2
DR_REGION=us-east-1

# Core SDK resolution
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=123456789012
USE_AWS_PROFILE=true
AWS_PROFILE=streamvault
# Or static keys (not recommended for laptops long-term):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

USE_IAM_ROLE=false

# Feature flags
ENABLE_SNS=true
ENABLE_SQS=true

# Resource names (fill from your account)
S3_BUCKET_NAME=streamvault-assets-prod
SNS_TOPIC_ARN=arn:aws:sns:us-west-2:123456789012:streamvault-alerts
SQS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/streamvault-events
EVENTBRIDGE_BUS_NAME=default
LAMBDA_RECOVERY_ARN=arn:aws:lambda:us-west-2:123456789012:function:streamvault-recovery
SAGEMAKER_ENDPOINT_NAME=streamvault-ed-lstm-endpoint

ROUTE53_HOSTED_ZONE_ID=
ROUTE53_PRIMARY_RECORD=
ROUTE53_DR_RECORD=

RDS_HOST=
RDS_PORT=3306
RDS_DATABASE=streamvault
RDS_USER=admin
RDS_PASSWORD=

DATABASE_URL=mysql+aiomysql://admin:PASSWORD@RDS_HOST:3306/streamvault
